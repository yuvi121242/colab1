{
  "expo": {
    "name": "Kaggle Mobile",
    "slug": "kaggle-mobile",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "kagglemobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "owner": "yuvi121242",
    "extra": {
      "eas": {
        "projectId": "auto"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kaggle.mobile",
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "processing"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#20BEFF"
      },
      "package": "com.kaggle.mobile",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-background-fetch", { "startOnBoot": true, "stopOnTerminate": false }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
